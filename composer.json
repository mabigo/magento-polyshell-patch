{
    "name": "markshust/magento2-module-polyshell-patch",
    "description": "Mitigates the PolyShell vulnerability (APSB25-94) — an unrestricted file upload in the Magento REST API that allows attackers to upload executable files via cart item custom option file uploads.",
    "type": "magento2-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Mark Shust",
            "email": "mark@m.academy",
            "homepage": "https://m.academy"
        }
    ],
    "require": {
        "php": ">=8.1",
        "magento/magento2-base": ">=2.4.5.0 <=2.4.5.14 || >=2.4.6.0 <=2.4.6.14 || >=2.4.7.0 <=2.4.7.9 || >=2.4.8.0 <=2.4.8.4",
        "magento/framework": "*",
        "magento/module-catalog": "*"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "MarkShust\\PolyshellPatch\\": ""
        }
    },
    "minimum-stability": "stable"
}
